# Application Environment: development, staging, or production
APP_ENV=development

# Logging configuration level
LOG_LEVEL=INFO

# Maximum concurrency limit for Playwright screenshot capture runs
MAX_CONCURRENCY_LIMIT=3

# External API Keys (Optional, zero hardcoded secrets default to empty/commented)

GEMINI_API_KEY=your_actual_key_here
GITHUB_TOKEN=your_actual_token_here